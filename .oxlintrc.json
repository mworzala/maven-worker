{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "ignorePatterns": ["node_modules", "coverage", ".wrangler", "dist"],
  "rules": {
    "no-console": "off"
  }
}
